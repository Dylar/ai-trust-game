{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "serviceName",
    "namespace",
    "environment",
    "component",
    "partOf",
    "replicas",
    "image",
    "containerPort",
    "servicePort",
    "probes",
    "resources",
    "config"
  ],
  "properties": {
    "serviceName": {
      "type": "string",
      "minLength": 1
    },
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "prod"]
    },
    "component": {
      "type": "string",
      "minLength": 1
    },
    "partOf": {
      "type": "string",
      "minLength": 1
    },
    "replicas": {
      "type": "integer",
      "minimum": 0
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "containerPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "servicePort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readiness", "liveness"],
      "properties": {
        "readiness": {
          "$ref": "#/definitions/httpProbe"
        },
        "liveness": {
          "$ref": "#/definitions/httpProbe"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "limits"],
      "properties": {
        "requests": {
          "$ref": "#/definitions/resourceSet"
        },
        "limits": {
          "$ref": "#/definitions/resourceSet"
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "httpProbe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "initialDelaySeconds",
        "periodSeconds",
        "timeoutSeconds",
        "failureThreshold"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "resourceSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpu", "memory"],
      "properties": {
        "cpu": {
          "type": "string",
          "minLength": 1
        },
        "memory": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
